{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@axiongraph/core": ["packages/core/src/index.ts"],
      "@axiongraph/store-local": ["packages/store-local/src/index.ts"],
      "@axiongraph/store-postgres": ["packages/store-postgres/src/index.ts"],
      "@axiongraph/store-convex": ["packages/store-convex/src/index.ts"],
      "@axiongraph/testkit": ["packages/testkit/src/index.ts"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
