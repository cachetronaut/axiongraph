{
  "name": "@axiongraph/store-postgres",
  "version": "0.0.0",
  "private": true,
  "description": "Internal: a durable GraphStore adapter backed by Postgres (pg). Published as the `axiongraph/store-postgres` subpath of the `axiongraph` package; `pg` is an optional peer dependency.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@axiongraph/core": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "devDependencies": {
    "@axiongraph/testkit": "workspace:*",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "vitest": "^2.1.8"
  }
}
