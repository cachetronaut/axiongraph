{
  "name": "@axiongraph/store-convex",
  "version": "0.0.0",
  "private": true,
  "description": "Internal: a GraphStore adapter backed by a Convex Component. Published as the `axiongraph/store-convex` (+ `/server`) subpaths; `convex` is an optional peer dependency.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "files": [
    "src",
    "component",
    "convex.json"
  ],
  "scripts": {
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "codegen": "convex codegen"
  },
  "dependencies": {
    "@axiongraph/core": "workspace:*"
  },
  "peerDependencies": {
    "convex": ">=1.17"
  },
  "devDependencies": {
    "@axiongraph/testkit": "workspace:*",
    "@edge-runtime/vm": "^4.0.0",
    "convex": "^1.17.0",
    "convex-test": "^0.0.37",
    "vitest": "^2.1.8"
  }
}
